<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AquaClient.Views.ProfilePage"
             >
    <ScrollView>
        <Grid RowDefinitions="Auto, Auto, *, Auto"
              RowSpacing="10"
              Padding="30, 20, 30, 30">

            <BoxView 
                Grid.Row="0" 
                BackgroundColor="#4090EE" 
                CornerRadius="12" 
                HeightRequest="300"/>
            <Grid 
                Grid.Row="0" 
                ColumnDefinitions="80, *, 80"
                RowDefinitions="80,*, 80"
                HeightRequest="300"
                VerticalOptions="Start"
                >
                <Label Grid.Column ="1" Grid.Row="0"
                    Text="Профиль"
                    Padding="10"
                    FontSize="22"
                    HorizontalOptions="Center"
                    TextColor="White"
                    />
                    <ImageButton 
                        Grid.Column="2" Grid.Row="0"
                        BackgroundColor="#4090EE"
                        Margin="10" 
                        Source="exit.png" 
                        Aspect="AspectFill"
                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, 
                                Path=BindingContext.LogoutCommand}"
                        />
                    <Border WidthRequest="150" Grid.Row="1" Grid.Column="1"
                        HeightRequest="150"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 9999">
                        <Image 
                            Source="user.png"
                            Aspect="AspectFill"
                            x:Name="profileAvatar"
                            />
                    </Border>
                    <ImageButton 
                        Grid.Row="2"
                        Grid.Column="1"
                        BackgroundColor="#4090EE"
                        Margin="0" 
                        Source="write.png" 
                        WidthRequest="30"          
                        HeightRequest="30"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        IsVisible="{Binding EditMode, Converter={StaticResource InverseBoolConverter}}"
                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, 
                                    Path=BindingContext.EditProfileCommand}"
                        />
            </Grid>

            <!-- Форма профиля -->
            <VerticalStackLayout Spacing="20" Grid.Row="2">

                <!-- Контейнер для полей ввода с Border -->
                <Border Stroke="#E0E0E0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Padding="0">

                    <VerticalStackLayout Spacing="0">
                        <!-- Поле Surname -->
                        <VerticalStackLayout Padding="20, 10" Spacing="5">
                            <Label Text="Фамилия" 
                                   FontSize="14" 
                                   TextColor="Gray"/>
                            <Entry x:Name="surnameEntry"
                                   
                                   Text="{Binding Surname}"
                                   ClearButtonVisibility="WhileEditing"
                                   TextColor="Gray"
                                   IsEnabled="{Binding EditMode}"
                                   FontSize="16"/>
                        </VerticalStackLayout>

                        <!-- Разделитель между полями -->
                        <BoxView HeightRequest="1" 
                                 BackgroundColor="#EEEEEE"/>

                        <!-- Поле Name -->
                        <VerticalStackLayout Padding="20, 10" Spacing="5">
                            <Label Text="Имя*" 
                                   FontSize="14" 
                                   TextColor="Gray"/>
                            <Entry x:Name="firstnameEntry"
                                   
                                   Text="{Binding Firstname}"
                                   ClearButtonVisibility="WhileEditing"
                                   TextColor="Gray"
                                   IsEnabled="{Binding EditMode}"
                                   FontSize="16"/>
                            <Label Text="Имя не должно быть пустым и состоять из букв"
                               TextColor="Red"
                               FontSize="12"
                               IsVisible="{Binding IsValidName, Converter={StaticResource InverseBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Разделитель между полями -->
                        <BoxView HeightRequest="1" 
                                 BackgroundColor="#EEEEEE"/>

                        <!-- Поле Middlename -->
                        <VerticalStackLayout Padding="20, 10" Spacing="5">
                            <Label Text="Отчество" 
                                   FontSize="14" 
                                   TextColor="Gray"/>
                            <Entry x:Name="middlenameEntry"
                                   
                                   Text="{Binding Middlename}"
                                   ClearButtonVisibility="WhileEditing"
                                   TextColor="Gray"
                                   IsEnabled="{Binding EditMode}"
                                   FontSize="16"/>
                        </VerticalStackLayout>

                        <!-- Разделитель между полями -->
                        <BoxView HeightRequest="1" 
                                 BackgroundColor="#EEEEEE"/>

                        <!-- Поле телефон -->
                        <VerticalStackLayout Padding="20, 10" Spacing="5">
                            <Label Text="Телефон*" 
                                   FontSize="14" 
                                   TextColor="Gray"/>
                            <Entry x:Name="phoneEntry"
                                   Text="{Binding Phone}"
                                   Placeholder="+79991234567"
                                   Keyboard="Telephone"
                                   ClearButtonVisibility="WhileEditing"
                                   TextColor="Gray"
                                   IsEnabled="{Binding EditMode}"
                                   FontSize="16"/>
                            <Label Text="Неверный формат телефона"
                               TextColor="Red"
                               FontSize="12"
                               IsVisible="{Binding IsValidPhone, Converter={StaticResource InverseBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Разделитель между полями -->
                        <BoxView HeightRequest="1" 
                                 BackgroundColor="#EEEEEE"/>

                        <!-- Поле Email -->
                        <VerticalStackLayout Padding="20, 10" Spacing="5">
                            <Label Text="Email*" 
                                   FontSize="14" 
                                   TextColor="Gray"/>
                            <Entry x:Name="emailEntry"
                                   Placeholder="Введите ваш E-mail*"
                                   Text="{Binding Email}"
                                   ClearButtonVisibility="WhileEditing"
                                   TextColor="Gray"
                                   IsEnabled="{Binding EditMode}"
                                   FontSize="16"/>
                            <Label Text="Неверный формат email"
                               TextColor="Red"
                               FontSize="12"
                               IsVisible="{Binding IsValidEmail, Converter={StaticResource InverseBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Разделитель между полями -->
                        <BoxView HeightRequest="1" 
                                 BackgroundColor="#EEEEEE"/>

                        <VerticalStackLayout IsVisible="{Binding EditMode}">
                            <!-- Поле Пароль -->
                            <VerticalStackLayout Padding="20, 10" Spacing="5">
                                <Label Text="Пароль*" 
                                       FontSize="14" 
                                       TextColor="Gray"/>
                                <Entry x:Name="passwordEntry"
                                       Placeholder="Введите текущий пароль"
                                       Text="{Binding Password}"
                                       IsPassword="True"
                                       ClearButtonVisibility="WhileEditing"
                                       TextColor="Gray"
                                       FontSize="16"/>
                            </VerticalStackLayout>

                            <!-- Разделитель между полями -->
                            <BoxView HeightRequest="1" 
                                     BackgroundColor="#EEEEEE"/>

                                                        <!-- Поле Пароль1 -->
                            <VerticalStackLayout Padding="20, 10" Spacing="5">
                                <Label Text="Пароль*" 
                                       FontSize="14" 
                                       TextColor="Gray"/>
                                <Entry x:Name="passwordEntry1"
                                       Placeholder="Введите новый пароль"
                                       Text="{Binding Password1}"
                                       IsPassword="True"
                                       ClearButtonVisibility="WhileEditing"
                                       TextColor="Gray"
                                       FontSize="16"/>
                                <Label Text="Пароль минимум 3 символа"
                                   TextColor="Red"
                                   FontSize="12"
                                   IsVisible="{Binding IsValidPassword1, Converter={StaticResource InverseBoolConverter}}"/>
                            </VerticalStackLayout>

                            <!-- Разделитель между полями -->
                            <BoxView HeightRequest="1" 
                                     BackgroundColor="#EEEEEE"/>

                            <!-- Поле Пароль2 -->
                            <VerticalStackLayout Padding="20, 10" Spacing="5">
                                <Label Text="Повторите пароль*" 
                                       FontSize="14" 
                                       TextColor="Gray"/>
                                <Entry x:Name="passwordEntry2"
                                       Placeholder="Подтвердите новый пароль"
                                       Text="{Binding Password2}"
                                       IsPassword="True"
                                       ClearButtonVisibility="WhileEditing"
                                       TextColor="Gray"
                                       FontSize="16"/>
                                <Label Text="Пароли не совпадают"
                                   TextColor="Red"
                                   FontSize="12"
                                   IsVisible="{Binding IsValidPassword2, Converter={StaticResource InverseBoolConverter}}"/>
                            </VerticalStackLayout>
                      </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- Кнопка входа и ссылка на регистрацию -->
            <VerticalStackLayout Spacing="5" Padding="10" Grid.Row="3">

                <!-- Кнопка Входа с Grid для индикатора -->
                <Grid>
                    <VerticalStackLayout Spacing="20" IsVisible="{Binding EditMode}">
                        <Button x:Name="SaveButton"
                            Text="СОХРАНИТЬ"
                            IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            CornerRadius="10"
                            HeightRequest="52"
                            FontSize="16"
                            FontAttributes="Bold"
                            Command="{Binding SaveProfileCommand}">
                            <Button.Triggers>
                                <Trigger TargetType="Button"
                                 Property="IsEnabled"
                                 Value="True">
                                    <Setter Property="BackgroundColor" Value="#512BD4"/>
                                    <Setter Property="TextColor" Value="White"/>
                                </Trigger>

                                <Trigger TargetType="Button"
                                 Property="IsEnabled"
                                 Value="False">
                                    <Setter Property="BackgroundColor" Value="#AAAAAA"/>
                                    <Setter Property="TextColor" Value="#666666"/>
                                </Trigger>
                            </Button.Triggers>
                        </Button>
                        <Button x:Name="CancelButton"
                            Text="ОТМЕНА"
                            IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            CornerRadius="10"
                            HeightRequest="52"
                            FontSize="16"
                            FontAttributes="Bold"
                            Command="{Binding CancelCommand}">
                            <Button.Triggers>
                                <Trigger TargetType="Button"
                                 Property="IsEnabled"
                                 Value="True">
                                    <Setter Property="BackgroundColor" Value="#772BD4"/>
                                    <Setter Property="TextColor" Value="White"/>
                                </Trigger>

                                <Trigger TargetType="Button"
                                 Property="IsEnabled"
                                 Value="False">
                                    <Setter Property="BackgroundColor" Value="#AAAAAA"/>
                                    <Setter Property="TextColor" Value="#666666"/>
                                </Trigger>
                            </Button.Triggers>
                        </Button>
                        <!-- Индикатор загрузки -->
                        <ActivityIndicator x:Name="activityIndicator"
                                       IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Color="#512BD4"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       WidthRequest="30"
                                       HeightRequest="30"
                                       Margin="0,0,0,0"/>
                    </VerticalStackLayout>

                </Grid>

            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>