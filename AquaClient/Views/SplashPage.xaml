<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AquaClient.Views.SplashPage"
             BackgroundColor="#0D47A1">

    <Grid>
        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">

            <!-- SVG изображение аквариума -->
            <Image Source="aquarium_splash.png"
                   WidthRequest="200"
                   HeightRequest="200"
                   HorizontalOptions="Center"/>

            <!-- Текст "Загрузка" -->
            <Label Text="Загрузка..."
                   TextColor="White"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <!-- Индикатор прогресса -->
            <ActivityIndicator IsRunning="True"
                               Color="White"
                               HorizontalOptions="Center"
                               WidthRequest="40"
                               HeightRequest="40"/>

        </VerticalStackLayout>
    </Grid>
</ContentPage>