<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AquaClient.Views.CameraPage">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <WebView x:Name="videoWebView"
                    Source="about:blank"
                    HeightRequest="400"
                    WidthRequest="600" />

            <Button Text="Включить камеру"
                    Clicked="StartClicked"
                     />

            <Button Text="Выключить камеру"
                    Clicked="StopClicked"
                     />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
