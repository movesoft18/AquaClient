<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="AquaClient.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AquaClient.Views"
    Title="AquaClient">

    <TabBar>

        <Tab Title="Управление" Icon="controls.png" >
            <ShellContent ContentTemplate="{DataTemplate views:AquaControlPage}" />
        </Tab>

        <Tab Title="Камера" Icon="camera.png">
            <ShellContent ContentTemplate="{DataTemplate views:CameraPage}" />
        </Tab>

        <Tab Title="Профиль" Icon="profile.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
        
        <Tab Title="О программе" Icon="about.png">
            <ShellContent ContentTemplate="{DataTemplate views:AboutPage}" />
        </Tab>

    </TabBar>

</Shell>
